{
  "run_name": "matgpt_pretrain_pubchem",
  "dataset": "pubchem_len20-290_no_ions_no_multi_random5M_123",

  "n_layer": 8,
  "n_head": 8,
  "n_embd": 256,
  "block_size": 340,

  "max_epochs": 30,
  "batch_size": 64,
  "learning_rate": 1e-4,
  "lr_decay": true,
  "warmup": 0.0001,
  "weight_decay": 0.1,
  "grad_norm_clip": 1.0,
  "aug_prob": 0.5,

  "vocab_path": null,
  "ckpt_save_path": "matgpt/ckpt",

  "use_tensorboard": true,
  "val_inter": 300,
  "save_epoch": 5,

  "continued_pretrain": false,
  "ckpt_load_path": null,
  "freeze_layers": 8,
  "keep_train_modules": ["head", "mlp"],
  "freeze_modules": [],

  "use_rotary": true,
  "use_rel_pos_bias": true,
  "use_gated_mlp": true,

  "use_diversity_loss": false,
  "diversity_weight": 0.1,
  "use_nucleus_sampling": false,
  "nucleus_p": 0.9,
  "use_temperature_annealing": false,
  "min_temperature": 0.5,
  "max_temperature": 1.5
